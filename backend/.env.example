PORT=3000
NODE_ENV=production

DB_HOST=localhost
DB_PORT=5432
DB_NAME=wmsm
DB_USER=wmsm_user
DB_PASSWORD=你的資料庫密碼

# 產生方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=請替換為32位元隨機hex字串
JWT_EXPIRES_IN=8h

# Gmail 郵件設定（UAT 草稿通知用）
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=麥頭印標系統簽核 <your-email@gmail.com>

# 前端網址（通知信中「前往系統」連結，不含結尾 /）
APP_URL=http://localhost:3000
